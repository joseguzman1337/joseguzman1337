{
  "name": "@cypress/request",
  "description": "Cypress's fork of a simplified HTTP request client.",
  "keywords": [
    "http",
    "simple",
    "util",
    "utility"
  ],
  "version": "3.0.10",
  "author": "Mikeal Rogers <mikeal.rogers@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/cypress-io/request.git"
  },
  "bugs": {
    "url": "http://github.com/cypress-io/request/issues"
  },
  "license": "Apache-2.0",
  "engines": {
    "node": ">= 6"
  },
  "main": "index.js",
  "files": [
    "lib/",
    "index.js",
    "request.js"
  ],
  "dependencies": {
    "aws-sign2": "~0.7.0",
    "aws4": "^1.13.2",
    "caseless": "~0.12.0",
    "combined-stream": "~1.0.8",
    "extend": "~3.0.2",
    "forever-agent": "~0.6.1",
    "form-data": "~4.0.5",
    "http-signature": "~1.4.0",
    "is-typedarray": "~1.0.0",
    "isstream": "~0.1.2",
    "json-stringify-safe": "~5.0.1",
    "mime-types": "~3.0.2",
    "performance-now": "^2.1.0",
    "qs": "~6.15.0",
    "safe-buffer": "^5.2.1",
    "tough-cookie": "^6.0.1",
    "tunnel-agent": "^0.6.0",
    "uuid": "^13.0.0"
  },
  "scripts": {
    "test": "npm run lint && npm run test-ci && npm run test-browser",
    "test-ci": "tap --no-check-coverage tests/test-*.js",
    "test-cov": "nyc --reporter=lcov tape tests/test-*.js",
    "test-browser": "echo 'Skipping browser tests.' || node tests/browser/start.js",
    "lint": "standard"
  },
  "devDependencies": {
    "bluebird": "^3.7.2",
    "browserify": "^17.0.1",
    "browserify-istanbul": "^3.0.1",
    "buffer-equal": "^1.0.1",
    "codecov": "^3.8.3",
    "coveralls": "^3.1.1",
    "function-bind": "^1.1.2",
    "karma": "^6.4.4",
    "karma-browserify": "^8.1.0",
    "karma-cli": "^2.0.0",
    "karma-coverage": "^2.2.1",
    "karma-phantomjs-launcher": "^1.0.4",
    "karma-tap": "^4.2.0",
    "nyc": "^18.0.0",
    "phantomjs-prebuilt": "^2.1.16",
    "rimraf": "^6.1.3",
    "server-destroy": "^1.0.1",
    "standard": "^17.1.2",
    "tap": "^21.6.2",
    "tape": "^5.9.0"
  },
  "greenkeeper": {
    "ignore": [
      "hawk",
      "har-validator"
    ]
  }
}
