  "license": "MIT",
  "devDependencies": {
    "eslint": "10.0.3",
    "expect.js": "0.3.1",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "mocha": "11.7.5",
    "prettier": "3.8.1"
  }
}
